<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape android:shape="oval">
            <solid android:alpha="0.3" android:color="@color/red_600" />
            <stroke android:width="1dp" android:color="@color/red_600" />
        </shape>
    </item>

    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:alpha="0.3" android:color="@color/red_600" />
            <stroke android:width="1dp" android:color="@color/red_600" />
        </shape>
    </item>

    <item>
        <shape android:shape="oval">
            <solid android:alpha="0.3" android:color="@android:color/transparent" />
            <stroke android:width="1dp" android:color="@color/grey_300" />
        </shape>
    </item>

</selector>