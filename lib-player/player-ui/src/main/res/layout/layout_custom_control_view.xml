<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
    tools:background="@color/black">

    <LinearLayout
            android:id="@+id/bottom_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/dkplayer_shape_stardard_controller_bottom_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal">

        <ImageView
                android:id="@+id/iv_play"
                android:layout_width="@dimen/dkplayer_controller_height"
                android:layout_height="@dimen/dkplayer_controller_height"
                android:layout_gravity="bottom"
                android:padding="@dimen/dp8"
                android:src="@drawable/dkplayer_selector_play_button" />

        <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">


            <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">


                <TextView
                        android:id="@+id/curr_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/dkplayer_controller_time_text_size"
                        tools:text="00:00" />

                <SeekBar
                        android:id="@+id/seekBar"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="10dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:max="1000"
                        android:maxHeight="2dp"
                        android:paddingStart="0dp"
                        android:paddingEnd="0dp"
                        android:progressDrawable="@drawable/dkplayer_layer_progress_bar"
                        android:thumb="@drawable/dkplayer_seekbar_thumb"
                        android:thumbOffset="0dp" />

                <TextView
                        android:id="@+id/total_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/dkplayer_controller_time_text_size"
                        tools:text="00:00" />

            </LinearLayout>

            <LinearLayout
                    android:id="@+id/full_container"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/dkplayer_controller_height"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_play_next"
                    android:layout_width="@dimen/dkplayer_controller_height"
                    android:layout_height="@dimen/dkplayer_controller_height"
                    android:layout_gravity="bottom"
                    android:padding="@dimen/dp8"
                    android:src="@drawable/ic_skip_next" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"/>

                <ImageView
                        android:id="@+id/iv_dm_show"
                        android:layout_width="@dimen/dkplayer_controller_height"
                        android:layout_height="@dimen/dkplayer_controller_height"
                        android:layout_marginStart="@dimen/dp8"
                        android:padding="@dimen/dp8"
                        android:src="@drawable/ic_danmu_selector"
                    android:contentDescription="@string/app_name" />

                <ImageView
                    android:id="@+id/iv_dm_conf"
                    android:layout_width="@dimen/dkplayer_controller_height"
                    android:layout_height="@dimen/dkplayer_controller_height"
                    android:layout_marginEnd="@dimen/dp8"
                    android:padding="@dimen/dp8"
                    android:src="@drawable/ic_danmu_config"
                    android:contentDescription="@string/app_name" />


                <TextView
                        android:id="@+id/tv_select_dm"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/dkplayer_controller_height"
                        android:paddingStart="@dimen/dp8"
                        android:paddingEnd="@dimen/dp8"
                        android:layout_marginEnd="@dimen/dp8"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:textColor="@android:color/white"
                        android:textSize="@dimen/dp16"
                        android:text="@string/action_select_dm"
                        tools:text="选弹幕"
                    tools:ignore="SpUsage" />


            </LinearLayout>

        </LinearLayout>

        <ImageView
                android:id="@+id/fullscreen"
                android:layout_width="@dimen/dkplayer_controller_height"
                android:layout_height="@dimen/dkplayer_controller_height"
                android:layout_gravity="bottom"
                android:padding="@dimen/dp8"
                android:src="@drawable/dkplayer_selector_full_screen_button" />

    </LinearLayout>

    <ProgressBar
            android:id="@+id/bottom_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_gravity="bottom"
            android:max="1000"
            android:progressDrawable="@drawable/dkplayer_layer_progress_bar"
            android:visibility="visible" />

</FrameLayout>