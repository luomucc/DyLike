<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_radius_8_selector"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="@dimen/dp12">

    <TextView
        android:id="@+id/chapter_index"
        android:layout_width="@dimen/dp24"
        android:layout_height="@dimen/dp24"
        android:background="@drawable/dkplayer_shape_stardard_controller_bottom_bg"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="@dimen/dp12"
        tools:text="1" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp12"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/chapter_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/white"
            android:textSize="@dimen/dp14"
            tools:text="Chapter 1" />

        <TextView
            android:id="@+id/chapter_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp4"
            android:textColor="@color/grey_300"
            android:textSize="@dimen/dp12"
            tools:text="00:00 - 05:30" />

    </LinearLayout>

    <ImageView
        android:id="@+id/chapter_playing"
        android:layout_width="@dimen/dp24"
        android:layout_height="@dimen/dp24"
        android:padding="@dimen/dp4"
        android:src="@drawable/ic_play_arrow_24"
        app:tint="@color/white"
        android:visibility="gone"
        tools:ignore="contentDescription" />

</LinearLayout>
