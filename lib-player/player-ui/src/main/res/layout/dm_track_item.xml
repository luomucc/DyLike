<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/select_dm"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="center_vertical"
    android:layout_marginBottom="@dimen/dp4"
    android:clickable="false"
    android:descendantFocusability="afterDescendants"
    android:focusable="false"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="0dp"
    android:paddingBottom="8dp"
    tools:ignore="MissingDefaultResource">

    <ImageView
        android:id="@+id/cb_select"
        android:layout_width="@dimen/dp32"
        android:layout_height="@dimen/dp40"
        android:padding="@dimen/dp4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_title"
        app:layout_constraintBottom_toBottomOf="@+id/tv_title"
        android:src="@drawable/ic_check_box_selector"
        android:visibility="gone"
        tools:visibility="visible"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/dp32"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/dp8"
        android:paddingEnd="@dimen/dp8"
        android:maxLines="3"
        android:text="@string/action_play"
        android:textColor="@color/grey300_accent50_selector"
        app:layout_constraintStart_toEndOf="@+id/cb_select"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/iv_action"
        android:textSize="@dimen/dp14"
        tools:text="第一行\n第二行\n第三行"
        tools:ignore="SpUsage" />

    <ImageView
        android:id="@+id/iv_action"
        android:layout_width="@dimen/dp40"
        android:layout_height="@dimen/dp40"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintTop_toTopOf="@+id/tv_title"
        app:layout_constraintBottom_toBottomOf="@+id/tv_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/ic_setting"
        app:tint="@color/grey_300"
        android:padding="8dp"
        tools:ignore="ContentDescription" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/content_offset_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/offset_hint"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp40"
            android:layout_marginStart="@dimen/dp8"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/hint_dm_offset"
            android:textColor="@color/grey_300"
            android:textSize="@dimen/dp16"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="SpUsage" />

        <TextView
            android:id="@+id/offset_sub_10"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:layout_marginStart="@dimen/dp10"
            android:background="@drawable/bd_oval_stroke_selector"
            android:gravity="center"
            android:maxLines="1"
            android:text="-10"
            android:textColor="@color/grey_300"
            android:textSize="@dimen/dp16"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/offset_hint"
            tools:ignore="SpUsage" />

        <TextView
            android:id="@+id/offset_sub_2"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:background="@drawable/bd_oval_stroke_selector"
            android:gravity="center"
            android:maxLines="1"
            android:text="-2"
            android:textColor="@color/grey_300"
            android:textSize="@dimen/dp16"
            app:layout_constraintEnd_toStartOf="@+id/offset_sub_0_5"
            app:layout_constraintStart_toEndOf="@+id/offset_sub_10"
            app:layout_constraintTop_toTopOf="@+id/offset_sub_10"
            tools:ignore="SpUsage" />

        <TextView
            android:id="@+id/offset_sub_0_5"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:background="@drawable/bd_oval_stroke_selector"
            android:gravity="center"
            android:maxLines="1"
            android:text="-0.5"
            android:textColor="@color/grey_300"
            android:textSize="@dimen/dp16"
            app:layout_constraintEnd_toStartOf="@+id/offset_add_0_5"
            app:layout_constraintStart_toEndOf="@+id/offset_sub_2"
            app:layout_constraintTop_toTopOf="@+id/offset_sub_10"
            tools:ignore="SpUsage" />

        <TextView
            android:id="@+id/offset_add_0_5"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:background="@drawable/bd_oval_stroke_selector"
            android:gravity="center"
            android:maxLines="1"
            android:text="+0.5"
            android:textColor="@color/grey_300"
            android:textSize="@dimen/dp16"
            app:layout_constraintEnd_toStartOf="@+id/offset_add_2"
            app:layout_constraintStart_toEndOf="@+id/offset_sub_0_5"
            app:layout_constraintTop_toTopOf="@+id/offset_sub_10"
            tools:ignore="SpUsage" />

        <TextView
            android:id="@+id/offset_add_2"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:background="@drawable/bd_oval_stroke_selector"
            android:gravity="center"
            android:maxLines="1"
            android:text="+2"
            android:textColor="@color/grey_300"
            android:textSize="@dimen/dp16"
            app:layout_constraintEnd_toStartOf="@+id/offset_add_10"
            app:layout_constraintStart_toEndOf="@+id/offset_add_0_5"
            app:layout_constraintTop_toTopOf="@+id/offset_sub_10"
            tools:ignore="SpUsage" />

        <TextView
            android:id="@+id/offset_add_10"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:layout_marginEnd="@dimen/dp8"
            android:background="@drawable/bd_oval_stroke_selector"
            android:gravity="center"
            android:maxLines="1"
            android:text="+10"
            android:textColor="@color/grey_300"
            android:textSize="@dimen/dp16"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/offset_sub_10"
            tools:ignore="SpUsage" />

        <TextView
            android:id="@+id/offset_value"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp40"
            android:layout_marginStart="@dimen/dp16"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/grey_300"
            android:textSize="@dimen/dp16"
            app:layout_constraintStart_toEndOf="@+id/offset_hint"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="SpUsage"
            tools:text="75" />

        <TextView
            android:id="@+id/offset_reset"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/dp40"
            android:background="@android:color/transparent"
            android:gravity="center"
            android:maxLines="1"
            android:paddingStart="@dimen/dp8"
            android:paddingEnd="@dimen/dp8"
            android:text="@string/action_reset"
            android:textColor="@color/view_accent"
            android:textSize="@dimen/dp16"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="SpUsage"
            tools:visibility="visible" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>