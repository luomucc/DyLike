<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ImageView
        android:id="@+id/play_btn"
        android:layout_width="@dimen/dp96"
        android:layout_height="@dimen/dp96"
        android:layout_gravity="center"
        android:background="@null"
        android:contentDescription="@string/app_name"
        android:scaleType="fitCenter"
        android:src="@drawable/dkplayer_selector_play_button"
        android:visibility="gone"
        app:tint="#B8FFFFFF"
        tools:visibility="visible" />

    <LinearLayout
        android:id="@+id/top_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="start|top"
        android:orientation="horizontal"
        android:padding="@dimen/dp8"
        tools:ignore="UseCompoundDrawables">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:contentDescription="@string/app_name"
            android:padding="@dimen/dp8"
            android:src="@drawable/ic_arrow_back" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp40"
            android:gravity="center_vertical"
            android:maxLines="1"
            tools:text="标题标题标题标题标题标题标题标题标题标题标题标题标题标题标题"
            android:textColor="@android:color/white"
            android:textSize="16sp" />
    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottom_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom">

        <ImageView
            android:id="@+id/iv_full_exit"
            android:layout_width="@dimen/dp40"
            android:layout_height="@dimen/dp40"
            android:gravity="center_vertical"
            android:padding="@dimen/dp8"
            android:src="@drawable/ic_fullscreen_exit_24"
            android:text="@string/hint_play_full"
            android:textColor="@color/white"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:visibility="visible"
            android:contentDescription="@string/app_name" />

        <TextView
            android:id="@+id/tv_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:paddingStart="@dimen/dp16"
            android:paddingEnd="@dimen/dp16"
            android:textColor="@android:color/white"
            android:textSize="16sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="@+id/play_seekbar"
            app:layout_constraintTop_toBottomOf="@+id/play_seekbar"
            tools:text="00:11 / 23:12" />

        <androidx.appcompat.widget.AppCompatSeekBar
            android:id="@+id/play_seekbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/dp32"
            android:background="@null"
            android:max="1000"
            android:progressBackgroundTint="@color/grey_500"
            android:progressTint="@color/grey_400"
            android:thumbTint="@color/grey_300"
            app:layout_constraintBottom_toTopOf="@id/iv_full_exit"
            tools:visibility="visible" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>