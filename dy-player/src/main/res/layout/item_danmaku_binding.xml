<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/dp4"
    android:layout_marginVertical="@dimen/dp2"
    android:background="@android:color/transparent">

    <ImageView
        android:id="@+id/item_move"
        android:layout_width="@dimen/dp24"
        android:layout_height="0dp"
        android:paddingHorizontal="@dimen/dp4"
        android:src="@drawable/ic_menu_24"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/item_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp4"
        android:layout_marginEnd="@dimen/dp2"
        android:paddingVertical="@dimen/dp2"
        android:minHeight="@dimen/dp32"
        android:ellipsize="middle"
        android:gravity="center_vertical"
        android:textSize="13sp"
        android:textColor="@color/text_primary"
        app:layout_constraintEnd_toStartOf="@+id/item_move"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/item_summary"
        tools:text="@string/app_name" />

    <TextView
        android:id="@+id/item_summary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp4"
        android:layout_marginEnd="@dimen/dp8"
        android:layout_marginBottom="@dimen/dp4"
        android:maxLines="2"
        android:minLines="1"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/item_move"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/item_title"
        tools:text="已绑定 1 个弹幕" />

</androidx.constraintlayout.widget.ConstraintLayout>
