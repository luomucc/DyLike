<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_secondary"
    android:padding="@dimen/dp16">

    <Space
        android:layout_width="560dp"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp40"
        app:layout_constraintTop_toTopOf="parent"
        app:title="@string/hint_short_title_strategy_dialog"
        app:titleCentered="true"/>

    <!-- 策略模式 Spinner -->
    <TextView
        android:id="@+id/tv_label_mode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp8"
        android:text="@string/hint_short_title_strategy_mode"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="@dimen/dp16"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar" />

    <androidx.appcompat.widget.AppCompatSpinner
        android:id="@+id/spinner_strategy_mode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="@dimen/dp120"
        app:layout_constraintBottom_toBottomOf="@id/tv_label_mode"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_label_mode" />

    <!-- 分隔符输入 -->
    <TextView
        android:id="@+id/tv_label_delimiter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp12"
        android:text="@string/hint_short_title_strategy_delimiter"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="@dimen/dp16"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_label_mode" />

    <TextView
        android:id="@+id/tv_label_delimiter_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/hint_short_title_strategy_delimiter_desc"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_label_delimiter" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/et_delimiter"
        android:layout_width="@dimen/dp80"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp4"
        android:gravity="center"
        android:maxLength="2"
        android:maxLines="1"
        android:textSize="@dimen/dp18"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_label_delimiter_desc"
        tools:text="-" />

    <!-- 最大行数 Spinner -->
    <TextView
        android:id="@+id/tv_label_max_lines"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp12"
        android:text="@string/hint_short_title_strategy_max_lines"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="@dimen/dp16"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_delimiter" />

    <androidx.appcompat.widget.AppCompatSpinner
        android:id="@+id/spinner_max_lines"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minWidth="@dimen/dp80"
        app:layout_constraintBottom_toBottomOf="@id/tv_label_max_lines"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_label_max_lines" />

    <!-- 正则输入（仅 REGEX_FIRST 模式启用） -->
    <TextView
        android:id="@+id/tv_label_regex"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp12"
        android:text="@string/hint_short_title_strategy_regex"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="@dimen/dp16"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_label_max_lines" />

    <TextView
        android:id="@+id/tv_label_regex_desc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/hint_short_title_strategy_regex_desc"
        android:textColor="?android:attr/textColorSecondary"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_label_regex" />

    <com.google.android.material.textfield.TextInputEditText
        android:id="@+id/et_regex"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp4"
        android:hint="^([^-]+)"
        android:maxLines="1"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_label_regex_desc" />

    <!-- 预览区域 -->
    <com.google.android.material.divider.MaterialDivider
        android:id="@+id/divider_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp16"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/et_regex" />

    <TextView
        android:id="@+id/tv_preview_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp8"
        android:text="@string/hint_short_title_strategy_preview"
        android:textColor="?android:attr/textColorPrimary"
        android:textSize="@dimen/dp16"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider_preview" />

    <TextView
        android:id="@+id/tv_preview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp8"
        android:background="@color/background_secondary"
        android:lineSpacingExtra="2dp"
        android:maxLines="5"
        android:padding="@dimen/dp8"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_preview_label"
        tools:text="UP\nVLOG\n这是一段文字" />

    <!-- 确认 / 取消 -->
    <Button
        android:id="@+id/button_confirmed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp16"
        android:minWidth="@dimen/dp40"
        android:text="@string/action_confirmed"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_preview" />

    <Button
        android:id="@+id/button_cancel"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dp16"
        android:minWidth="@dimen/dp40"
        android:text="@string/action_cancel"
        app:layout_constraintEnd_toStartOf="@+id/button_confirmed"
        app:layout_constraintTop_toTopOf="@+id/button_confirmed" />

</androidx.constraintlayout.widget.ConstraintLayout>
