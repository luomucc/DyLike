<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:titleCentered="true"
        app:title="@string/title_about"
        app:layout_constraintTop_toTopOf="parent"/>

    <ImageView
        android:id="@+id/iv_app_logo"
        android:layout_width="@dimen/dp64"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp32"
        app:layout_constraintTop_toBottomOf="@+id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:src="@mipmap/ic_launcher"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/tv_app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp16"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/iv_app_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:text="@string/app_name"/>

    <TextView
        android:id="@+id/tv_version"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp8"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_app_name"
        android:text="@string/app_name"/>

    <TextView
        android:id="@+id/tv_feedback_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp48"
        android:layout_marginStart="@dimen/dp32"
        android:textColor="@color/text_secondary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_version"
        android:text="反馈Q群"/>

    <TextView
        android:id="@+id/tv_feedback"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@+id/tv_feedback_hint"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="@dimen/dp16"
        android:paddingStart="@dimen/dp32"
        android:paddingEnd="16dp"
        android:text="811806197"/>

    <TextView
        android:id="@+id/tv_public_license_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_feedback_hint"
        android:layout_marginTop="@dimen/dp16"
        android:layout_marginStart="@dimen/dp32"
        android:text="开源协议"/>

    <TextView
        android:id="@+id/tv_public_license"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@+id/tv_public_license_hint"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="@dimen/dp16"
        android:paddingStart="@dimen/dp32"
        android:paddingEnd="16dp"
        android:textColor="@color/blue_150"
        android:text="暂无"/>

    <TextView
        android:id="@+id/tv_app_record_hint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_public_license_hint"
        android:layout_marginTop="@dimen/dp16"
        android:layout_marginStart="@dimen/dp32"
        android:text="App备案号"/>

    <TextView
        android:id="@+id/tv_app_record"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="@+id/tv_app_record_hint"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginEnd="@dimen/dp16"
        android:paddingStart="@dimen/dp32"
        android:paddingEnd="16dp"
        android:text="暂无"/>

    <TextView
        android:id="@+id/tv_protocol"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="4dp"
        android:gravity="center"
        android:textColor="@color/blue_150"
        app:layout_constraintBottom_toTopOf="@+id/tv_copyright"
        android:text="DyLike服务协议"/>

    <TextView
        android:id="@+id/tv_copyright"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/dp32"
        android:padding="@dimen/dp16"
        android:gravity="center"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        android:text="DyLike © 2025零次版权所有"/>

</androidx.constraintlayout.widget.ConstraintLayout>