<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/dp16">

    <TextView
        android:id="@+id/text_title"
        android:layout_width="match_parent"
        android:layout_height="@dimen/dp40"
        android:gravity="center"
        android:text="文件浏览设置"
        android:textColor="?attr/colorPrimary"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_global"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp8"
        android:layout_marginBottom="@dimen/dp8"
        android:text="全局"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/text_title"/>

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/sw_used_all"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="设置应用于所有页面"
        app:layout_constraintTop_toBottomOf="@+id/tv_global"/>

    <TextView
        android:id="@+id/tv_sort"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp8"
        android:layout_marginBottom="@dimen/dp8"
        android:text="排序"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/sw_used_all"/>

    <RadioGroup
        android:id="@+id/rg_sort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@+id/tv_sort">

        <RadioButton
            android:id="@+id/rb_name_up"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="文件名正序"/>

        <RadioButton
            android:id="@+id/rb_name_down"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="文件名倒序"/>

        <RadioButton
            android:id="@+id/rb_time_up"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="修改时间正序"/>

        <RadioButton
            android:id="@+id/rb_time_down"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="修改时间倒叙"/>

    </RadioGroup>

    <TextView
        android:id="@+id/tv_other"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp8"
        android:layout_marginBottom="@dimen/dp8"
        android:text="其他"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rg_sort"/>

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/sw_show_hide"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="显示隐藏文件夹"
        app:layout_constraintTop_toBottomOf="@+id/tv_other"/>

</androidx.constraintlayout.widget.ConstraintLayout>