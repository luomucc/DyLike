<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground"
    tools:context=".ui.media.MediaFragment">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/button_select_folder"
        style="@style/Widget.Material3.Button.ElevatedButton.Icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dp16"
        android:minWidth="@dimen/dp40"
        android:minHeight="@dimen/dp40"
        android:visibility="visible"
        tools:visibility="visible"
        app:icon="@drawable/ic_add_24"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/toolbar"
        android:text="@string/action_select_dir"/>

    <TextView
        android:id="@+id/tv_dm_track"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/dp16"
        app:layout_constraintTop_toTopOf="@+id/button_select_folder"
        app:layout_constraintBottom_toBottomOf="@+id/button_select_folder"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/button_select_folder"
        android:minLines="1"
        android:maxLines="2"
        tools:text="已绑定2个弹幕轨道"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/left_recycler_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:paddingStart="@dimen/dp8"
        android:paddingEnd="@dimen/dp8"
        app:layout_constraintBottom_toTopOf="@+id/layout_batch"
        app:layout_constraintEnd_toStartOf="@+id/right_recycler_view"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/button_select_folder" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/right_recycler_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:overScrollMode="never"
        android:paddingStart="@dimen/dp8"
        android:paddingEnd="@dimen/dp8"
        app:layout_constraintBottom_toTopOf="@+id/layout_batch"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/left_recycler_view"
        app:layout_constraintTop_toTopOf="@+id/left_recycler_view" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout_batch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        tools:visibility="visible"
        android:paddingStart="@dimen/dp16"
        android:paddingEnd="@dimen/dp16"
        app:layout_constraintBottom_toBottomOf="parent">

        <Button
            android:id="@+id/button_positive"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/dp40"
            android:minHeight="@dimen/dp40"
            android:visibility="visible"
            tools:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:text="@string/action_positive"
            />

        <Button
            android:id="@+id/button_exit"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/dp40"
            android:minHeight="@dimen/dp40"
            android:visibility="visible"
            tools:visibility="visible"
            app:layout_constraintEnd_toStartOf="@+id/button_positive"
            app:layout_constraintBottom_toBottomOf="parent"
            android:text="@string/action_exit"
            />

        <Button
            android:id="@+id/button_select_invert"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/dp40"
            android:minHeight="@dimen/dp40"
            android:visibility="gone"
            tools:visibility="visible"
            app:layout_constraintStart_toEndOf="@+id/button_select_all"
            app:layout_constraintBottom_toBottomOf="parent"
            android:text="@string/action_select_invert"
            />

        <Button
            android:id="@+id/button_select_all"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="@dimen/dp40"
            android:minHeight="@dimen/dp40"
            android:visibility="gone"
            tools:visibility="visible"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:text="@string/action_select_all"
            />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>